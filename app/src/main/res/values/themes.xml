<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.FolkGarderoba" parent="Theme.MaterialComponents.Light.NoActionBar">

        <!-- Fix popup menu text color -->
        <item name="android:textColorPrimary">@android:color/black</item>
        <item name="android:textColorSecondary">@android:color/black</item>

        <!-- Optional but recommended -->
        <item name="colorOnSurface">@android:color/black</item>
        <item name="colorSecondary">@color/headerfooter</item>
        <item name="colorControlActivated">@color/headerfooter</item>
        <item name="colorControlHighlight">@color/headerfooter</item>


    </style>
    <style name="PopupMenuDark" parent="ThemeOverlay.AppCompat.Dark">
        <item name="android:popupBackground">@color/headerfooter</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="BadgeText">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="EditTextCursorColor">
        <item name="android:textCursorDrawable">@drawable/edittext_cursor_headerfooter</item>
    </style>

    <style name="SmallCheckBox" parent="Widget.AppCompat.CompoundButton.CheckBox">
        <item name="android:button">@drawable/abc_btn_check_material</item>
        <item name="android:textSize">18sp</item>
    </style>

</resources>